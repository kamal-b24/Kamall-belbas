{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "CallLog": {
      "title": "Call Log",
      "description": "History of voice calls with professors",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who made the call" },
        "professorId": { "type": "string", "description": "ID of the professor called" },
        "duration": { "type": "number", "description": "Duration of the call in seconds" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the call started" }
      },
      "required": ["userId", "professorId", "duration", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/calls/{callId}": {
      "schema": "CallLog",
      "description": "Logs of all professor calls"
    }
  }
}
